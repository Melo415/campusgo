<view class="hair-salon-list-container"><view class="filter-bar"><view class="filter-item"><text>理发店</text><icon type="arrowdown" size="20"></icon></view><view class="filter-item"><text>距离</text><icon type="arrowdown" size="20"></icon></view><view class="filter-item"><text>评分</text><icon type="arrowdown" size="20"></icon></view><view class="filter-item"><text>价格</text><icon type="arrowdown" size="20"></icon></view></view><view class="hair-salons"><view wx:for="{{a}}" wx:for-item="item" wx:key="j" class="hair-salon-item"><view class="hair-salon-image"><image src="{{item.a}}" mode="aspectFill"></image></view><view class="hair-salon-details"><view class="hair-salon-name">{{item.b}}</view><view class="rating"><text wx:for="{{item.c}}" wx:for-item="star" wx:key="a" class="star">★</text><text wx:if="{{item.d}}" class="half-star">☆</text><text class="score">({{item.e}})</text><text class="review-count">{{item.f}}条评论</text></view><view class="services"><text wx:for="{{item.g}}" wx:for-item="service" wx:key="b" class="service-item">{{service.a}}</text></view><view class="price">人均消费：￥{{item.h}}/次</view><view class="address">{{item.i}}</view></view></view></view></view>