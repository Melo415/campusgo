/* 水平间距 */
/* 水平间距 */
.hair-salon-list-container {
  background-color: #fff;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  justify-content: space-around;
  padding: 10px;
  border-bottom: 1px solid #ccc;
}
.filter-bar .filter-item {
  display: flex;
  align-items: center;
}
.filter-bar .filter-item text {
  margin-right: 5px;
}

/* 理发店列表 */
.hair-salons {
  padding: 10px;
}
.hair-salon-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 15px;
  padding: 10px;
  border: 1px solid #eee;
  border-radius: 5px;
}

/* 理发店图片 */
.hair-salon-image {
  width: 100px;
  height: 100px;
  margin-right: 15px;
  border-radius: 5px;
  overflow: hidden;
}
.hair-salon-image image {
  width: 100%;
  height: 100%;
}

/* 理发店详情 */
.hair-salon-details {
  flex: 1;
}

/* 理发店名称 */
.hair-salon-name {
  font-size: 18px;
  font-weight: bold;
  margin-bottom: 8px;
}

/* 评分和评论数 */
.rating {
  display: flex;
  align-items: center;
  margin-bottom: 8px;
}
.rating .star {
  color: gold;
  margin-right: 2px;
}
.rating .half-star {
  color: #ccc;
  position: relative;
  margin-right: 2px;
}
.rating .half-star::after {
  content: "☆";
  position: absolute;
  left: 0;
  top: 0;
  color: gold;
  width: 50%;
  overflow: hidden;
}
.rating .score {
  margin-left: 5px;
  color: #666;
  font-size: 14px;
}
.rating .review-count {
  margin-left: 10px;
  color: #999;
  font-size: 14px;
}

/* 服务项目 */
.services {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 8px;
}
.services .service-item {
  background-color: #f8f8f8;
  border: 1px solid #eee;
  border-radius: 3px;
  padding: 3px 8px;
  margin-right: 5px;
  margin-bottom: 5px;
  font-size: 12px;
  color: #666;
}

/* 人均消费 */
.price {
  margin-bottom: 8px;
  color: #ff5722;
  font-size: 16px;
}

/* 地址 */
.address {
  color: #666;
  font-size: 14px;
}