/* 水平间距 */
.message-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}
.message-container .header {
  background-color: #ffffff;
  padding: 20rpx 30rpx;
  padding-top: calc(20rpx + var(--status-bar-height));
  border-bottom: 1rpx solid #eee;
}
.message-container .header .title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}
.message-container .notification-list {
  height: calc(100vh - 88rpx - var(--status-bar-height));
}
.message-container .empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}
.message-container .empty-state .empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}
.message-container .empty-state .empty-text {
  color: #999;
  font-size: 28rpx;
}
.message-container .notification-item {
  display: flex;
  padding: 30rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #eee;
}
.message-container .notification-item.unread {
  background-color: #f0f7ff;
}
.message-container .notification-item.unread::before {
  content: "";
  position: absolute;
  left: 15rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background-color: #ff4d4f;
}
.message-container .notification-item .sender-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}
.message-container .notification-item .notification-content {
  flex: 1;
}
.message-container .notification-item .notification-content .notification-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}
.message-container .notification-item .notification-content .notification-header .sender-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}
.message-container .notification-item .notification-content .notification-header .notification-time {
  font-size: 24rpx;
  color: #999;
}
.message-container .notification-item .notification-content .notification-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
}