/* 水平间距 */
.edit-profile {
  background-color: #f5f5f5;
  min-height: 100vh;
}
.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  padding-top: calc(var(--status-bar-height) + 20rpx);
  /* 考虑状态栏高度 */
  background-color: #ffffff;
  border-bottom: 1rpx solid #eaeaea;
  position: -webkit-sticky;
  position: sticky;
  top: 0;
  z-index: 99;
  /* 新增：控制标题图片样式 */
}
.page-header .back-btn,
.page-header .save-btn {
  font-size: 30rpx;
  color: #666;
}
.page-header .save-btn {
  color: #07C160;
  font-weight: 500;
}
.page-header .title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}
.page-header .header-icon {
  width: 150rpx;
  /* 调整宽度 */
  height: 80rpx;
  /* 调整高度 */
}
.form-container {
  padding: 15px;
  background-color: #fff;
}
.form-container .form-item {
  margin-bottom: 20px;
}
.form-container .form-item .label {
  display: block;
  font-size: 14px;
  color: #333;
  margin-bottom: 8px;
}
.form-container .form-item .input {
  width: 100%;
  height: 40px;
  padding: 0 10px;
  border: 1px solid #eee;
  border-radius: 4px;
  font-size: 14px;
}
.form-container .form-item .textarea {
  width: 100%;
  height: 80px;
  padding: 10px;
  border: 1px solid #eee;
  border-radius: 4px;
  font-size: 14px;
}
.form-container .avatar-upload .avatar-preview {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 10px;
}
.form-container .avatar-upload .avatar-preview .avatar {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  margin-bottom: 8px;
}
.form-container .avatar-upload .avatar-preview .upload-tip {
  font-size: 12px;
  color: #999;
}
.form-container .gender-select {
  display: flex;
  gap: 20px;
}
.form-container .gender-select .gender-option {
  flex: 1;
  height: 40px;
  line-height: 40px;
  text-align: center;
  border: 1px solid #eee;
  border-radius: 4px;
  font-size: 14px;
  color: #666;
}
.form-container .gender-select .gender-option.active {
  background-color: #07C160;
  color: #fff;
  border-color: #07C160;
}