/* 水平间距 */
/* 水平间距 */
.personal-home {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 60px;
  /* 移除 padding-top 和 box-sizing */
}
.status-bar-bg {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background-image: url("data:image/png;base64,");
  background-size: cover;
  background-position: center;
  z-index: 10;
  /* 确保在内容之上 */
  transition: opacity 0.3s;
  /* 可选：添加过渡效果 */
}
.background-wrapper {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 340px;
  overflow: hidden;
  z-index: 1;
}
.background-wrapper .bg-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: blur(10px);
  transform: scale(1.1);
}
.background-wrapper .bg-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.2) 0%, rgba(0, 0, 0, 0.4) 100%);
}
.content-wrapper {
  position: relative;
  z-index: 2;
  padding-bottom: 60px;
  margin-top: -30px;
  /* 恢复负边距 */
}
.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 16px 12px;
  /* 保持顶部固定 padding 为 0 */
  /* padding-top 由 inline style 控制 */
}
.header-bar .left-section .title {
  font-size: 22px;
  font-weight: 600;
  color: #fff;
}
.header-bar .right-section .setting-btn {
  background: rgba(255, 255, 255, 0.2);
  padding: 6px 12px;
  border-radius: 16px;
}
.header-bar .right-section .setting-btn text {
  color: #fff;
  font-size: 14px;
}
.user-info-section {
  padding: 0 16px 12px;
  display: flex;
  align-items: flex-start;
  margin-top: 10px;
}
.user-info-section .user-avatar {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  overflow: hidden;
  border: 2px solid rgba(255, 255, 255, 0.8);
  margin-right: 16px;
}
.user-info-section .user-avatar image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.user-info-section .user-details {
  flex: 1;
}
.user-info-section .user-details .user-name {
  font-size: 20px;
  font-weight: 600;
  color: #fff;
  margin-bottom: 4px;
}
.user-info-section .user-details .user-status {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 8px;
}
.user-info-section .user-details .user-location {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 12px;
  display: flex;
  align-items: center;
}
.user-info-section .user-details .user-location .iconfont {
  margin-right: 4px;
}
.user-info-section .user-details .action-buttons {
  display: flex;
  gap: 12px;
}
.user-info-section .user-details .action-buttons button {
  height: 32px;
  line-height: 32px;
  font-size: 14px;
  border-radius: 16px;
  padding: 0 16px;
}
.user-info-section .user-details .action-buttons .edit-button {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  border: 1px solid rgba(255, 255, 255, 0.3);
}
.user-info-section .user-details .action-buttons .logout-button {
  background: #ff2442;
  color: #fff;
  border: none;
}
.stats-section {
  background: #fff;
  border-radius: 12px 12px 0 0;
  margin-top: -4px;
  padding: 20px 0;
  display: flex;
  justify-content: space-around;
}
.stats-section .stat-item {
  text-align: center;
}
.stats-section .stat-item .stat-number {
  font-size: 18px;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 4px;
}
.stats-section .stat-item .stat-label {
  font-size: 12px;
  color: #999;
}
.tab-bar {
  display: flex;
  background-color: white;
  border-bottom: 1px solid #eaeaea;
}
.tab-bar .tab {
  flex: 1;
  text-align: center;
  padding: 12px 0;
  font-size: 15px;
  color: #666;
}
.tab-bar .tab.active {
  color: #07C160;
  border-bottom: 2px solid #07C160;
}
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 20px;
  background-color: white;
}
.empty-state .empty-image {
  width: 160px;
  height: 160px;
  margin-bottom: 20px;
  border-radius: 50%;
  padding: 10px;
  box-sizing: border-box;
  background-color: #fff;
  object-fit: contain;
}
.empty-state .empty-text {
  font-size: 16px;
  color: #888;
  margin-bottom: 20px;
  text-align: center;
}
.empty-state .empty-button {
  background-color: #07C160;
  color: white;
  border: none;
  border-radius: 20px;
  padding: 8px 20px;
  font-size: 14px;
}
.notes-container,
.evaluations-container,
.fans-container,
.follow-container {
  background-color: white;
  min-height: 300px;
}
.note-item {
  padding: 12px 15px;
  border-bottom: 1px solid #f0f0f0;
  background-color: white;
}
.note-item:last-child {
  border-bottom: none;
}
.note-item .note-content .note-title {
  font-size: 16px;
  font-weight: bold;
  margin-bottom: 5px;
  display: block;
}
.note-item .note-content .note-text {
  font-size: 14px;
  margin-bottom: 8px;
  display: block;
  color: #333;
}
.note-item .note-content .note-images {
  display: flex;
  flex-wrap: wrap;
  margin: 10px 0;
}
.note-item .note-content .note-images .note-image {
  width: calc(33.33% - 6px);
  height: 100px;
  margin: 3px;
  border-radius: 4px;
  object-fit: cover;
}
.note-item .note-content .note-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.note-item .note-content .note-meta .note-time {
  color: #888;
  font-size: 12px;
}
.note-item .note-content .note-meta .note-interaction {
  display: flex;
  align-items: center;
}
.note-item .note-content .note-meta .note-interaction .interaction-item {
  display: flex;
  align-items: center;
  margin-right: 15px;
}
.note-item .note-content .note-meta .note-interaction .interaction-item .interaction-icon {
  width: 16px;
  height: 16px;
  margin-right: 4px;
}
.note-item .note-content .note-meta .note-interaction .interaction-item .interaction-count {
  font-size: 12px;
  color: #888;
}
.note-item .note-content .note-meta .note-interaction .delete-btn {
  padding: 2px 8px;
  background-color: #ff4d4f;
  color: white;
  border: none;
  border-radius: 4px;
  font-size: 12px;
}
.evaluation-item {
  padding: 15px;
  border-bottom: 1px solid #f0f0f0;
  background-color: white;
}
.evaluation-item .evaluation-content .blog-info {
  margin-bottom: 15px;
  padding: 10px;
  background-color: #f8f8f8;
  border-radius: 8px;
}
.evaluation-item .evaluation-content .blog-info .blog-header {
  display: flex;
  align-items: center;
  margin-bottom: 10px;
}
.evaluation-item .evaluation-content .blog-info .blog-header .blog-user-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}
.evaluation-item .evaluation-content .blog-info .blog-header .blog-user-name {
  font-size: 24rpx;
  color: #666;
}
.evaluation-item .evaluation-content .blog-info .blog-preview .blog-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 5px;
  display: block;
}
.evaluation-item .evaluation-content .blog-info .blog-preview .blog-content {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8px;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.evaluation-item .evaluation-content .blog-info .blog-preview .blog-images {
  display: flex;
  flex-wrap: wrap;
}
.evaluation-item .evaluation-content .blog-info .blog-preview .blog-images .blog-image {
  width: 120rpx;
  height: 120rpx;
  margin: 5rpx;
  border-radius: 4px;
  object-fit: cover;
}
.evaluation-item .evaluation-content .comment-section .comment-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  margin-bottom: 10px;
}
.evaluation-item .evaluation-content .comment-section .comment-meta {
  display: flex;
  justify-content: flex-end;
  align-items: center;
}
.evaluation-item .evaluation-content .comment-section .comment-meta .comment-time {
  font-size: 24rpx;
  color: #999;
}
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 50px;
  background-color: white;
  display: flex;
  border-top: 1px solid #eaeaea;
}
.bottom-nav .nav-item {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 14px;
  color: #666;
}
.bottom-nav .nav-item.active {
  color: #07C160;
}
.not-login-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40px 20px;
  background-color: white;
  margin-bottom: 10px;
}
.not-login-section .default-avatar {
  width: 100px;
  height: 100px;
  border-radius: 50%;
  margin-bottom: 20px;
}
.not-login-section .login-tip {
  font-size: 16px;
  color: #666;
  margin-bottom: 20px;
}
.not-login-section .login-button {
  background-color: #07C160;
  color: white;
  border: none;
  border-radius: 20px;
  padding: 8px 30px;
  font-size: 16px;
}
.follow-list {
  padding: 15px;
  background-color: white;
}
.follow-list .follow-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px;
  margin-bottom: 10px;
  background-color: #f8f8f8;
  border-radius: 8px;
  transition: all 0.3s ease;
}
.follow-list .follow-item:active {
  background-color: #f0f0f0;
}
.follow-list .follow-item .follow-user-info {
  display: flex;
  align-items: center;
  flex: 1;
}
.follow-list .follow-item .follow-user-info .follow-avatar {
  width: 50px;
  height: 50px;
  border-radius: 50%;
  margin-right: 12px;
  border: 2px solid #f0f0f0;
}
.follow-list .follow-item .follow-user-info .follow-info {
  flex: 1;
}
.follow-list .follow-item .follow-user-info .follow-info .follow-name {
  font-size: 16px;
  font-weight: bold;
  color: #333;
  margin-bottom: 4px;
  display: block;
}
.follow-list .follow-item .follow-user-info .follow-info .follow-signature {
  font-size: 12px;
  color: #666;
  display: block;
}
.follow-list .follow-item .unfollow-btn {
  padding: 4px 12px;
  font-size: 12px;
  color: #ff4d4f;
  background-color: white;
  border: 1px solid #ff4d4f;
  border-radius: 4px;
  margin-left: 10px;
}
.follow-list .follow-item .unfollow-btn:active {
  background-color: #fff1f0;
}
.evaluation-empty-image {
  width: 120px !important;
  /* 使用 !important 确保覆盖通用样式 */
  height: 120px !important;
}