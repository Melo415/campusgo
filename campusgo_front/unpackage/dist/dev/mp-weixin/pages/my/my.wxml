<view class="personal-home"><view class="page-title">个人中心</view><view class="user-info-section"><view class="user-avatar"><image src="{{a}}" mode="aspectFill"></image></view><view class="user-details"><view class="user-name">{{b}} <text class="user-status">({{c}})</text></view><view class="user-location">{{d}}</view><view class="action-buttons"><button class="edit-button" bindtap="{{e}}">编辑资料</button><button class="logout-button" bindtap="{{f}}">退出登录</button></view></view></view><view class="bio-input-section"><view class="input-container"><input class="bio-input" placeholder="{{g}}" bindfocus="{{h}}" bindblur="{{i}}" value="{{j}}" bindinput="{{k}}"/><button class="send-button" disabled="{{l}}" bindtap="{{m}}" style="{{'background-color:' + n}}"> 发送 </button></view></view><view class="tab-bar"><view class="{{['tab', o && 'active']}}" bindtap="{{p}}">笔记</view><view class="{{['tab', q && 'active']}}" bindtap="{{r}}">评价</view><view class="{{['tab', t && 'active']}}" bindtap="{{v}}">粉丝({{s}})</view><view class="{{['tab', x && 'active']}}" bindtap="{{y}}">关注({{w}})</view></view><view wx:if="{{z}}" class="notes-container"><view wx:if="{{A}}" class="empty-state"><image class="empty-image" src="{{B}}" mode="aspectFit"></image><text class="empty-text">你还没有发过任何一条笔记哦~</text><button class="empty-button" bindtap="{{C}}">去发布笔记</button></view><block wx:else><view wx:for="{{D}}" wx:for-item="note" wx:key="f" class="note-item"><view class="note-content"><text class="note-title">{{note.a}}</text><text class="note-text">{{note.b}}</text><view class="note-meta"><text class="note-time">{{note.c}}</text><view class="note-interaction"><button class="delete-btn" bindtap="{{note.d}}">删除</button><text class="like-count">{{note.e}}</text></view></view></view></view></block></view><view wx:if="{{E}}" class="evaluations-container"><view wx:if="{{F}}" class="empty-state"><image class="empty-image" src="{{G}}" mode="aspectFit"></image><text class="empty-text">你还没有发表过任何评价哦~</text></view><block wx:else><view wx:for="{{H}}" wx:for-item="evaluation" wx:key="a" class="evaluation-item"></view></block></view><view wx:if="{{I}}" class="fans-container"><view wx:if="{{J}}" class="empty-state"><image class="empty-image" src="{{K}}" mode="aspectFit"></image><text class="empty-text">还没有人关注你哦，快去发布优质内容吧~</text></view><view wx:else></view></view><view wx:if="{{L}}" class="follow-container"><view wx:if="{{M}}" class="empty-state"><image class="empty-image" src="{{N}}" mode="aspectFit"></image><text class="empty-text">你还没有关注任何人哦~</text><button class="empty-button" bindtap="{{O}}">去发现有趣的人</button></view><view wx:else></view></view><view class="bottom-nav"><view class="{{['nav-item', P && 'active']}}" bindtap="{{Q}}"><text>首页</text></view><view class="{{['nav-item', R && 'active']}}" bindtap="{{S}}"><text>消息</text></view><view class="{{['nav-item', T && 'active']}}" bindtap="{{U}}"><text>笔记</text></view><view class="{{['nav-item', V && 'active']}}" bindtap="{{W}}"><text>个人中心</text></view></view></view>