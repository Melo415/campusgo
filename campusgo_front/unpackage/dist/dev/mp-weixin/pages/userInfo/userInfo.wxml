<view class="user-profile"><view class="user-header"><view class="user-info"><image src="{{a}}" class="user-avatar" mode="aspectFill"></image><view class="user-details"><text class="user-name">{{b}}</text><text class="user-signature">{{c}}</text><view class="user-stats"><view class="stat-item"><text class="stat-num">{{d}}</text><text class="stat-label">关注</text></view><view class="stat-item"><text class="stat-num">{{e}}</text><text class="stat-label">粉丝</text></view><view class="stat-item"><text class="stat-num">{{f}}</text><text class="stat-label">笔记</text></view></view></view></view><button wx:if="{{g}}" class="{{['follow-btn', i && 'active']}}" bindtap="{{j}}">{{h}}</button></view><view class="blog-list"><view class="blog-title">Ta的笔记</view><view wx:if="{{k}}" class="empty-state"><image src="{{l}}" mode="aspectFit" class="empty-image"></image><text class="empty-text">暂无笔记</text></view><view wx:else class="blog-items"><view wx:for="{{m}}" wx:for-item="blog" wx:key="i" class="blog-item" bindtap="{{blog.j}}"><text class="blog-content-title">{{blog.a}}</text><text class="blog-content-text">{{blog.b}}</text><view wx:if="{{blog.c}}" class="blog-images"><image wx:for="{{blog.d}}" wx:for-item="img" wx:key="a" src="{{img.b}}" mode="aspectFill" class="blog-image" catchtap="{{img.c}}"></image></view><view class="blog-meta"><text class="blog-time">{{blog.e}}</text><view class="blog-stats"><view class="stat-item"><image src="{{blog.f}}" class="stat-icon"></image><text class="stat-num">{{blog.g}}</text></view><view class="stat-item"><image src="{{n}}" class="stat-icon"></image><text class="stat-num">{{blog.h}}</text></view></view></view></view></view></view></view>