/* 水平间距 */
.user-profile {
  min-height: 100vh;
  background-color: #f8f8f8;
  padding-bottom: 20px;
}
.user-header {
  background-color: #fff;
  padding: 20px;
  margin-bottom: 10px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}
.user-header .user-info {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20px;
}
.user-header .user-info .user-avatar {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  margin-right: 15px;
  border: 2px solid #f0f0f0;
  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.1);
}
.user-header .user-info .user-details {
  flex: 1;
}
.user-header .user-info .user-details .user-name {
  font-size: 18px;
  font-weight: bold;
  color: #333;
  margin-bottom: 5px;
  display: block;
}
.user-header .user-info .user-details .user-signature {
  font-size: 14px;
  color: #666;
  margin-bottom: 15px;
  display: block;
  line-height: 1.4;
}
.user-header .user-info .user-details .user-stats {
  display: flex;
}
.user-header .user-info .user-details .user-stats .stat-item {
  margin-right: 20px;
  text-align: center;
}
.user-header .user-info .user-details .user-stats .stat-item .stat-num {
  font-size: 16px;
  font-weight: bold;
  color: #333;
  margin-right: 5px;
}
.user-header .user-info .user-details .user-stats .stat-item .stat-label {
  font-size: 12px;
  color: #666;
}
.user-header .follow-btn {
  width: 100%;
  height: 36px;
  line-height: 36px;
  text-align: center;
  background-color: #07C160;
  color: #fff;
  border-radius: 18px;
  font-size: 14px;
  border: none;
  transition: all 0.3s ease;
}
.user-header .follow-btn.active {
  background-color: #f5f5f5;
  color: #666;
}
.user-header .follow-btn:active {
  transform: scale(0.98);
}
.blog-list {
  background-color: #fff;
  padding: 15px;
}
.blog-list .blog-title {
  font-size: 16px;
  font-weight: bold;
  color: #333;
  margin-bottom: 15px;
  padding-left: 10px;
  border-left: 3px solid #07C160;
}
.blog-list .empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30px 0;
}
.blog-list .empty-state .empty-image {
  width: 100px;
  height: 100px;
  margin-bottom: 15px;
}
.blog-list .empty-state .empty-text {
  font-size: 14px;
  color: #999;
}
.blog-list .blog-items .blog-item {
  padding: 15px;
  border-bottom: 1px solid #f0f0f0;
}
.blog-list .blog-items .blog-item:last-child {
  border-bottom: none;
}
.blog-list .blog-items .blog-item .blog-content-title {
  font-size: 16px;
  font-weight: bold;
  color: #333;
  margin-bottom: 8px;
  display: block;
}
.blog-list .blog-items .blog-item .blog-content-text {
  font-size: 14px;
  color: #666;
  line-height: 1.5;
  margin-bottom: 10px;
  display: block;
}
.blog-list .blog-items .blog-item .blog-images {
  display: flex;
  flex-wrap: wrap;
  margin: 10px 0;
}
.blog-list .blog-items .blog-item .blog-images .blog-image {
  width: calc(33.33% - 6px);
  height: 100px;
  margin: 3px;
  border-radius: 4px;
  object-fit: cover;
}
.blog-list .blog-items .blog-item .blog-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 10px;
}
.blog-list .blog-items .blog-item .blog-meta .blog-time {
  font-size: 12px;
  color: #999;
}
.blog-list .blog-items .blog-item .blog-meta .blog-stats {
  display: flex;
  align-items: center;
}
.blog-list .blog-items .blog-item .blog-meta .blog-stats .stat-item {
  display: flex;
  align-items: center;
  margin-left: 15px;
}
.blog-list .blog-items .blog-item .blog-meta .blog-stats .stat-item .stat-icon {
  width: 16px;
  height: 16px;
  margin-right: 4px;
}
.blog-list .blog-items .blog-item .blog-meta .blog-stats .stat-item .stat-num {
  font-size: 12px;
  color: #666;
}