/* 水平间距 */
.entertainment-container {
  min-height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: #f5f5f5;
}
.entertainment-container .construction-box {
  background-color: #ffffff;
  padding: 40rpx 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 80%;
  max-width: 600rpx;
  margin-top: -15vh;
}
.entertainment-container .construction-box .construction-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}
.entertainment-container .construction-box .construction-text {
  font-size: 36rpx;
  color: #333333;
  font-weight: bold;
  margin-bottom: 20rpx;
}
.entertainment-container .construction-box .construction-subtext {
  font-size: 28rpx;
  color: #666666;
}